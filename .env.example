# Database - Supabase PostgreSQL
DATABASE_URL=postgresql://postgres.xxx:password@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Auth - JWT
JWT_SECRET=your-jwt-secret-here

# Auth - Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Auth - Apple Sign-In
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key

# AI - Gemini (recipe tidying)
GEMINI_API_KEY=your-gemini-api-key

# AI - Stable Diffusion (image generation)
STABILITY_API_KEY=your-stability-api-key

# Storage - Google Cloud Storage
GCS_BUCKET=sgrecipebook-images
GCS_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# App
APP_URL=http://localhost:5173
OWNER_OPEN_ID=your-oauth-open-id

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
